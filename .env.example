# JWT for the lead-shopping link payload
RENTBASKET_JWT_SECRET=7QX2M9A4L5Z8R1T6C3K0H2F9D8P7B4
# Optional: paste a pre-signed token to skip on-boot signing
RENTBASKET_JWT=

# Firebase credentials (choose one of three methods)
# Option 1: base64-encoded service account JSON (recommended for Render)
FIREBASE_CREDENTIALS_JSON=
# Option 2: path to service account JSON file
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
# Option 3: Google Application Default Credentials
GOOGLE_APPLICATION_CREDENTIALS=

# Bot tuning
BOT_NAME=Ku
